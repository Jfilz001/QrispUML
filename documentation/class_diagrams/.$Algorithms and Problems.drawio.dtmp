ion&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;u&gt;+ custom(&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;label_list: List&amp;lt;Object&amp;gt;,&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;decoder: callable = none,&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;qs: QuantumSession = none,&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;name: String = none&lt;/u&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;): CustomQuantumVariable&lt;/u&gt;&lt;/div&gt;&lt;div&gt;+ decoder(&lt;/div&gt;&lt;div&gt;i: int&lt;/div&gt;&lt;div&gt;): String&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ is_deleted():&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ duplicate(&lt;/div&gt;&lt;div&gt;name: String=null,&lt;/div&gt;&lt;div&gt;qs: QuantumSession = null,&lt;/div&gt;&lt;div&gt;init: bool = false,&lt;/div&gt;&lt;div&gt;qubits: List&amp;lt;Qubit&amp;gt;&lt;/div&gt;&lt;div&gt;): QuantumVariable&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ encode(&lt;/div&gt;&lt;div&gt;value: String,&lt;/div&gt;&lt;div&gt;permit_dirtyness: bool = false&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ encoder(&lt;/div&gt;&lt;div&gt;value: String&lt;/div&gt;&lt;div&gt;): int&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ ensure_reg(): List&amp;lt;Qubit&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ extend(&lt;/div&gt;&lt;div&gt;amount: int,&lt;/div&gt;&lt;div&gt;position: int = -1&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+ get_meas&lt;span style=&quot;background-color: transparent;&quot;&gt;urement(&lt;/span&gt;&lt;div&gt;plot: bool = false,&lt;/div&gt;&lt;div&gt;backend: BackendClient = null,&lt;/div&gt;&lt;div&gt;shots: int = null,&lt;/div&gt;&lt;div&gt;compile: bool = true,&lt;/div&gt;&lt;div&gt;compilation_kwargs: Map&amp;lt;Object, Object&amp;gt;,&lt;/div&gt;&lt;div&gt;subs_dic,&lt;/div&gt;&lt;div&gt;circuit_preprocessor: callable = null,&lt;/div&gt;&lt;div&gt;filename: String = null,&lt;/div&gt;